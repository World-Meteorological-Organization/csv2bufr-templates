{
    "conformsTo": "csv2bufr-template-v2.json",
    "metadata": {
        "label": "Surface land stations export from Climsoft CDMS",
        "description": "Mapping template for converting CSV data from Climsoft to BUFR sequence 301150, 307080",
        "version": "1",
        "author": "David I. Berry",
        "editor": "",
        "dateCreated": "2025-10-03",
        "dateModified": "",
        "id": "e29a0d19-dcc8-4194-bddd-2e5239c9aee8"
    },
    "inputShortDelayedDescriptorReplicationFactor": [],
    "inputDelayedDescriptorReplicationFactor": [1,1],
    "inputExtendedDelayedDescriptorReplicationFactor": [],
    "number_header_rows": 1,
    "column_names_row": 1,
    "quoting": "QUOTE_NONE",
    "header":[
        {"eccodes_key": "edition", "value": "const:4"},
        {"eccodes_key": "masterTableNumber", "value": "const:0"},
        {"eccodes_key": "updateSequenceNumber", "value": "const:0"},
        {"eccodes_key": "dataCategory", "value": "const:0"},
        {"eccodes_key": "internationalDataSubCategory", "value": "const:2"},
        {"eccodes_key": "masterTablesVersionNumber", "value": "const:30"},
        {"eccodes_key": "numberOfSubsets", "value": "const:1"},
        {"eccodes_key": "observedData", "value": "const:1"},
        {"eccodes_key": "compressedData", "value": "const:0"},
        {"eccodes_key": "typicalYear", "value": "data:Datetime_Year"},
        {"eccodes_key": "typicalMonth", "value": "data:Datetime_Month"},
        {"eccodes_key": "typicalDay", "value": "data:Datetime_Day"},
        {"eccodes_key": "typicalHour", "value": "data:Datetime_Hour"},
        {"eccodes_key": "typicalMinute", "value": "data:Datetime_Minute"},
        {"eccodes_key": "unexpandedDescriptors", "value":"array:301150, 307080"}
    ],
    "data": [
        {"eccodes_key": "#1#wigosIdentifierSeries",                                "value":"data:wsi_series"},
        {"eccodes_key": "#1#wigosIssuerOfIdentifier",                              "value":"data:wsi_issuer"},
        {"eccodes_key": "#1#wigosIssueNumber",                                     "value":"data:wsi_issue_number"},
        {"eccodes_key": "#1#wigosLocalIdentifierCharacter",                        "value":"data:wsi_local"},
        {"eccodes_key": "#1#stationOrSiteName",                                    "value":"data:Station_Name"},
        {"eccodes_key": "#1#stationType",                                          "value":"data:Station_Type"},
        {"eccodes_key": "#1#year",                                                 "value":"data:Datetime_Year",       "valid_min": "const:2000", "valid_max": "const:2100"},
        {"eccodes_key": "#1#month",                                                "value":"data:Datetime_Month",      "valid_min": "const:1", "valid_max": "const:12"},
        {"eccodes_key": "#1#day",                                                  "value":"data:Datetime_Day", "valid_min": "const:1", "valid_max": "const:31"},
        {"eccodes_key": "#1#hour",                                                 "value":"data:Datetime_Hour",  "valid_min": "const:0", "valid_max": "const:23"},
        {"eccodes_key": "#1#minute",                                               "value":"data:Datetime_Minute",    "valid_min": "const:0", "valid_max": "const:59"},
        {"eccodes_key": "#1#latitude",                                             "value":"data:Latitude",     "valid_min": "const:-90", "valid_max": "const:90"},
        {"eccodes_key": "#1#longitude",                                            "value":"data:Longitude",    "valid_min": "const:-180", "valid_max": "const:180"},
        {"eccodes_key": "#1#heightOfStationGroundAboveMeanSeaLevel",               "value":"data:Elevation"},
        {"eccodes_key": "#1#heightOfBarometerAboveMeanSeaLevel",                   "value":"data:Pressure_Elevation"},
        {"eccodes_key": "#1#nonCoordinatePressure",                                "value":"data:Pressure_Barometric"},
        {"eccodes_key": "#1#pressureReducedToMeanSeaLevel",                        "value":"data:Pressure_QNH"},
        {"eccodes_key": "#1#3HourPressureChange",                                  "value":"data:Pressure_3Hchange", "valid_min": "const:-5000", "valid_max": "const:5230"},
        {"eccodes_key": "#1#heightOfSensorAboveLocalGroundOrDeckOfMarinePlatform", "value":"data:Temperature_Height"},
        {"eccodes_key": "#1#airTemperature",                                       "value":"data:Temperature_Drybulb"},
        {"eccodes_key": "#1#dewpointTemperature",                                  "value":"data:Temperature_Dewpoint"},
        {"eccodes_key": "#1#relativeHumidity",                                     "value":"data:Relative_Humidity"},
        {"eccodes_key": "#2#timePeriod",                                           "value":"data:Sunshine_Period"},
        {"eccodes_key": "#1#totalSunshine",                                        "value":"data:Sunshine_1Htotal"},
        {"eccodes_key": "#3#timePeriod",                                           "value":"const:-24"},
        {"eccodes_key": "#2#totalSunshine",                                        "value":"data:Sunshine_24Htotal"},
        {"eccodes_key": "#5#heightOfSensorAboveLocalGroundOrDeckOfMarinePlatform", "value":"data:Rain_Height"},
        {"eccodes_key": "#4#timePeriod",                                           "value":"const:-24"},
        {"eccodes_key": "#1#totalPrecipitationOrTotalWaterEquivalent",             "value":"data:Rain_24Htotal"},
        {"eccodes_key": "#6#heightOfSensorAboveLocalGroundOrDeckOfMarinePlatform", "value":"data:Temperature_Height"},
        {"eccodes_key": "#6#timePeriod",                                           "value":"data:Tmax_Period"},
        {"eccodes_key": "#7#timePeriod",                                           "value":"const:0"},
        {"eccodes_key": "#1#maximumTemperatureAtHeightAndOverPeriodSpecified",     "value":"data:Temperature_Tmax"},
        {"eccodes_key": "#8#timePeriod",                                           "value":"data:Tmin_Period"},
        {"eccodes_key": "#9#timePeriod",                                           "value":"const:0"},
        {"eccodes_key": "#1#minimumTemperatureAtHeightAndOverPeriodSpecified",     "value":"data:Temperature_Tmin"},
        {"eccodes_key": "#7#heightOfSensorAboveLocalGroundOrDeckOfMarinePlatform", "value":"data:Wind_Height"},
        {"eccodes_key": "#1#instrumentationForWindMeasurement",                    "value":"data:Wind_Type"},
        {"eccodes_key": "#1#timeSignificance",                                     "value":"data:Wind_Sig"},
        {"eccodes_key": "#10#timePeriod",                                          "value":"data:Wind_Period"},
        {"eccodes_key": "#1#windDirection",                                        "value":"data:Wind_Direction"},
        {"eccodes_key": "#1#windSpeed",                                            "value":"data:Wind_Speed"},
        {"eccodes_key": "#1#maximumWindGustSpeed",                                 "value":"data:WindGust_Speed"},
        {"eccodes_key": "#14#timePeriod",                                          "value":"data:Radiation_Period"},
        {"eccodes_key": "#1#globalSolarRadiationIntegratedOverPeriodSpecified",    "value":"data:Radiation_Total"}
    ]
}